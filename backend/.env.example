# Copy this file to .env and fill in real values. Never commit .env.
# Local/Docker Postgres:
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"
# Neon: use the POOLED connection string (hostname has "-pooler", add pgbouncer=true) —
# see README "Setup instructions" for why.
# DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="8h"
PORT=3001
CORS_ORIGIN="http://localhost:3000"
