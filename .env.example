# TaskFlow — environment variables reference
#
# This root file documents every variable the app needs. Once the backend/frontend
# projects are scaffolded (Phase 1), each app also gets its own .env.example:
#   backend/.env.example
#   frontend/.env.example
# Copy the relevant one to backend/.env and frontend/.env.local and fill in real values.
# Never commit a file named ".env" or ".env.local" with real secrets.

# ---- backend/.env ----
DATABASE_URL="postgresql://user:password@localhost:5432/taskflow?schema=public"
JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="8h"
PORT=3001
CORS_ORIGIN="http://localhost:3000"

# ---- frontend/.env.local ----
NEXT_PUBLIC_API_URL="http://localhost:3001/api"
